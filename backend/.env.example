# Copy to backend/.env and fill in. Never commit the real .env.

# OpenRouter agent (used from Phase 5 onward).
# Verified slug (2026-05-30): deepseek/deepseek-v4-flash. Fallback: deepseek/deepseek-v3.2.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Storage for uploaded files + SQLite DB (relative to backend/).
DATA_DIR=data

# Ingestion (Phase 1): PDF render DPI, thumbnail width (px), max upload size (MB).
RENDER_DPI=200
THUMBNAIL_WIDTH=400
MAX_UPLOAD_MB=25

# Pre-flight quality thresholds (Phase 2). All advisory (warn-only); tweak live on camera.
MIN_DPI=100
BLUR_WARN=60.0
CONTRAST_WARN=30.0
BLANK_INK_RATIO=0.01                # ink-pixel fraction below this = near-blank page (skips contrast warn)
BRIGHTNESS_DARK=50.0
SKEW_DESKEW_DEG=2.0
PRESCAN_NORMALIZE_WIDTH=1000
ASSUMED_PAGE_HEIGHT_IN=11.0

# OCR engine layer (Phase 3). Engines are swappable via ?engine= on the OCR route.
OCR_DEFAULT_ENGINE=docling          # used when ?engine= is omitted (qwen-vl | docling | mock)
PRE_WARM_MODELS=false               # true = load OCR models at startup (set for the demo)
OCR_DEVICE=cpu                      # cpu | gpu | mps (macOS demo runs on cpu)
OCR_CONFIDENCE_WARN=0.80            # avg block confidence below this adds a warning
OCR_TIMEOUT_S=600                   # OCR wall-clock ceiling (generous for cold model download)
LLM_TIMEOUT_S=120                   # structuring + decision (network LLM) wall-clock ceiling
# "qwen-vl" OCR engine: a vision-language model over OpenRouter (reuses OPENROUTER_API_KEY,
# needs the `agent` extra). No local models; bills per call. Docling stays the local default.
OCR_VLM_MODEL=qwen/qwen3-vl-235b-a22b-instruct
OCR_VLM_BASE_URL=https://openrouter.ai/api/v1

# Structuring (Phase 4). LangExtract -> validated JSON. Reuses OPENROUTER_API_KEY.
# The "langextract" provider is optional (uv sync --extra langextract); "mock" is offline.
STRUCTURING_PROVIDER=langextract    # langextract | mock
# Verified slug (2026-05-30): deepseek/deepseek-v4-flash. Fallback: deepseek/deepseek-v3.2.
STRUCTURING_MODEL=deepseek/deepseek-v4-flash
STRUCTURING_BASE_URL=https://openrouter.ai/api/v1
STRUCTURING_MAX_CHAR_BUFFER=8000
STRUCTURING_EXTRACTION_PASSES=2     # >1 improves recall (helps multi-clause contracts) at ~2x latency
EXTRACTION_CONFIDENCE_WARN=0.60     # overall extraction conf below this adds a warning

# Agent decision layer (Phase 5). Reuses OPENROUTER_API_KEY. The "llm" provider is
# optional (uv sync --extra agent); "mock" is offline. Thresholds/rules are env-
# overridable so they can be tweaked live on camera.
DECISION_PROVIDER=llm               # llm | mock
DECISION_MODEL=deepseek/deepseek-v4-flash   # verified 2026-05-30; fallback deepseek/deepseek-v3.2
DECISION_BASE_URL=https://openrouter.ai/api/v1
INVOICE_AUTO_APPROVE_MAX=10000.0    # invoice total over this -> needs_review
INVOICE_TOTAL_TOLERANCE=0.01        # allowed |total - (subtotal + tax)|
INVOICE_FLAG_ON_BANK_DETAILS=false  # true -> presence of bank details forces a flag
CONTRACT_VALUE_REVIEW_THRESHOLD=100000.0    # contract value over this -> needs_review
CONTRACT_ALLOWED_GOVERNING_LAW=["Delaware","England and Wales","New York","California"]

# Form-fill mapping (Phase 1, Wave 3). Suggests catalogue-path bindings for a
# fillable PDF's form fields. Reuses OPENROUTER_API_KEY. The "llm" provider is
# optional; "mock" (token-overlap heuristic) is offline and the no-key fallback.
MAPPING_PROVIDER=llm                 # llm | mock
MAPPING_MODEL=deepseek/deepseek-v4-flash    # verified 2026-05-30; fallback deepseek/deepseek-v3.2
MAPPING_BASE_URL=https://openrouter.ai/api/v1

# Authoring agent (Phase 3). A tool-calling agent edits a template's HTML/CSS.
# Reuses OPENROUTER_API_KEY. The "llm" provider is optional; "mock" is offline.
AGENT_AUTHORING_PROVIDER=llm         # llm | mock
AGENT_AUTHORING_MODEL=deepseek/deepseek-v4-flash    # verified 2026-05-30; fallback deepseek/deepseek-v3.2
AGENT_AUTHORING_BASE_URL=https://openrouter.ai/api/v1
AGENT_AUTHORING_MAX_TOOL_ITERATIONS=6   # tool-call rounds before the agent stops
AGENT_AUTHORING_TIMEOUT_S=120           # per-request wall-clock ceiling

# Vision-QA layer (Phase 4). A multimodal call judges a rendered template PDF against a
# reference (or the described HTML) for visual-fidelity issues. Reuses OPENROUTER_API_KEY.
# The "llm" provider is optional (uv sync --extra agent --extra docgen); "mock" is offline
# and the graceful fallback on any key/network/parse failure.
QA_VISION_PROVIDER=llm               # llm | mock
QA_VISION_MODEL=qwen/qwen3-vl-235b-a22b-instruct
QA_VISION_BASE_URL=https://openrouter.ai/api/v1
QA_TIMEOUT_S=180                     # per-request wall-clock ceiling
QA_RENDER_DPI=120                    # rasterize the preview PDF to PNG at this DPI
QA_MAX_PAGES=5                       # cap images sent to the judge (adds a truncation warning)

# Outbound digital signing (Phase 6). A separate, manual post-decision action (NOT in the
# inbound pipeline): an APPROVED document is sealed with a real X.509 signature that
# validates against a trust chain. The "pyhanko" provider is optional
# (uv sync --extra signing); "mock" is offline and covers tests.
SIGNING_PROVIDER=pyhanko             # pyhanko | mock (mock is offline, no extra deps)
SIGNING_LEVEL=PAdES-B-B             # PAdES-B-B | PAdES-B-T (B-T needs a TSA URL below)
SIGNING_TSA_URL=                    # RFC 3161 timestamp authority URL; set to enable B-T
SIGNING_FIELD_NAME=Signature1
SIGNING_REASON=Approved for transmission
SIGNING_LOCATION=
SIGNING_SIGNER_NAME=Document Approval Demo Signer
SIGNING_CA_COMMON_NAME=Document Approval Demo CA
# Draw a VISIBLE signature stamp (at the template's signature marker if the generated
# document has one, else the fallback position below) in addition to the cryptographic
# signature. false => a valid but invisible signature (only shown in a signature-aware
# viewer like Acrobat).
SIGNING_VISIBLE=true
# Fallback placement when a generated document carries NO signature marker (the
# template's <img data-signature> defines the spot otherwise). Position is
# top/bottom-left/center/right; page is 1-based.
SIGNING_VISIBLE_POSITION=bottom-right
SIGNING_VISIBLE_PAGE=1
# Demo server-held seal (custody option A): a self-signed CA+leaf minted on first use and
# reused thereafter. Resolved relative to backend/, kept OUTSIDE data/ (private keys must
# never be downloadable via /files) and gitignored. NOT for production.
SIGNING_CERT_DIR=certs
SIGNING_TIMEOUT_S=60                 # signing/validation wall-clock ceiling

# Comma/JSON list of allowed browser origins. Defaults to the Vite dev server.
# CORS_ORIGINS=["http://localhost:5173"]
